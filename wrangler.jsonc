{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "appealcompass",
  "main": "src/worker/index.ts",
  "compatibility_date": "2024-11-01",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "vars": {
    "ENVIRONMENT": "development"
  }
}
